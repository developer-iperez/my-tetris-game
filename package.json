{
  "name": "my-tetris-game",
  "version": "0.1.0",
  "private": true,
  "description": "Tetris en el navegador (motor desacoplado, Canvas 2D, PWA).",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "serve": "npm run build && browser-sync start --server --port 8080 --no-open --no-notify --no-ui --files \"dist/**/*.js\" \"css/**/*.css\" \"index.html\" \"manifest.json\"",
    "dev": "npm run build && concurrently -k \"npm:watch\" \"browser-sync start --server --port 8080 --no-open --no-notify --no-ui --files 'dist/**/*.js' 'css/**/*.css' 'index.html' 'manifest.json'\""
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "concurrently": "^10.0.3",
    "typescript": "^5.9.3"
  }
}
